# .env.example
#
# Consumed by docker-compose.yml to configure the postgres, redis,
# backend, and frontend services. Copy to .env and adjust as needed:
#   cp .env.example .env
#
# Every variable already has a safe default baked into docker-compose.yml,
# so `docker compose up` works out of the box even without a .env file -
# this is only needed if you want to customize ports/credentials.

# --- PostgreSQL ---
DB_NAME=classavo_db
DB_USER=classavo_user
DB_PASSWORD=your_password_here
DB_PORT=5432

# --- Redis ---
# Used by Django cache, Celery, Channels, and live-session state.
REDIS_PORT=6379

# --- Django backend ---
SECRET_KEY=docker-compose-local-dev-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend
CORS_ALLOWED_ORIGINS=http://localhost:3000
BACKEND_PORT=8000

# --- React frontend ---
REACT_APP_API_URL=http://localhost:8000/api
FRONTEND_PORT=3000
