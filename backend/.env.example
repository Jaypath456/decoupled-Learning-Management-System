# .env.example
DB_NAME=classavo_db
DB_USER=classavo_user
DB_PASSWORD=your_password_here
DB_HOST=127.0.0.1
DB_PORT=5432

# Used for Django's cache backend and as the Celery broker/result
# backend. Defaults to a local Redis instance if unset.
REDIS_URL=redis://127.0.0.1:6379/0

# Django core settings
# Generate a unique value with:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=change-me-to-a-unique-secret-value
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated list of frontend origins allowed to call this API
CORS_ALLOWED_ORIGINS=http://localhost:3000
